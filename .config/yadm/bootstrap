#!/bin/bash
# yadm bootstrap — run after `yadm clone` or `yadm pull` on any machine
# Installs/updates npm dependencies for pi extensions that have a package.json

set -euo pipefail

echo "==> yadm bootstrap"

# Reset the manual followups file. Tasks in bootstrap.yml append commands here
# that the user needs to run by hand (things ansible can't do for them, like
# steps that need TCC permissions or interactive input). The contents are
# printed at the end of the bootstrap run.
FOLLOWUPS_FILE=/tmp/bootstrap-followups.txt
rm -f "$FOLLOWUPS_FILE"

# Install a sudoers drop-in granting passwordless sudo for $USER on first run.
# Reason: ansible's shell tasks run in subprocesses that don't inherit sudo's
# tty-bound credential cache, so `sudo -v` priming is useless once ansible takes
# over. A drop-in in /etc/sudoers.d/ is the standard solution. Only prompts once,
# the first time bootstrap is ever run on a new machine. Remove with:
#   sudo rm /etc/sudoers.d/${USER}-bootstrap
if [[ "$OSTYPE" == "darwin"* ]]; then
  SUDOERS_DROPIN="/etc/sudoers.d/${USER}-bootstrap"
  if [[ ! -f "$SUDOERS_DROPIN" ]]; then
    echo "  Installing passwordless sudo drop-in at $SUDOERS_DROPIN"
    echo "  (one-time prompt for your login password)"
    echo "${USER} ALL=(ALL) NOPASSWD: ALL" | sudo tee "$SUDOERS_DROPIN" > /dev/null
    sudo chmod 440 "$SUDOERS_DROPIN"
    echo "  Done. Future bootstrap runs will not prompt."
  else
    echo "  Passwordless sudo drop-in already present at $SUDOERS_DROPIN"
  fi
fi

# macOS-specific configuration
if [[ "$OSTYPE" == "darwin"* ]]; then
  echo "  Configuring macOS screenshot and screen recording locations..."
  
  # Create both directories 
  mkdir -p "$HOME/screenshots"
  mkdir -p "$HOME/screen-recordings"
  
  # Configure default location for screenshots and screen recordings (Cmd+Shift+3, Cmd+Shift+4, Cmd+Shift+5)
  # Note: macOS Screenshot app uses the same location setting for both by default
  defaults write com.apple.screencapture location "$HOME/screenshots"
  
  # Apply the changes by restarting SystemUIServer
  killall SystemUIServer 2>/dev/null || true
  
  echo "  Screenshots (Cmd+Shift+3/4) will save to ~/screenshots/"
  echo "  Screen recordings (Cmd+Shift+5) default to ~/screenshots/"
  echo "  Screen Organizer app will auto-compress and move recordings to ~/screen-recordings/"
  
  # Install essential packages via Homebrew
  if command -v brew >/dev/null 2>&1; then
    echo "  Installing/updating essential packages..."
    
    # Core development and media tools
    BREW_PACKAGES=(
      "ffmpeg"          # Video processing for screen recording compression
      "imagemagick"     # Image optimization for screenshots
      "orbstack"        # Modern Docker desktop alternative
      "eza"             # Better ls replacement (already used in .zshrc)
      "fzf"             # Fuzzy finder (already used in .zshrc)
      "zsh-autosuggestions"  # Shell autocompletion (already used in .zshrc)
      "git"             # Latest git version
      "gh"              # GitHub CLI
      "jq"              # JSON processor
      "ripgrep"         # Better grep
      "fd"              # Better find
      "bat"             # Better cat
      "tldr"            # Simplified man pages
      "htop"            # Better top
    )
    
    for package in "${BREW_PACKAGES[@]}"; do
      if brew list "$package" >/dev/null 2>&1; then
        echo "    ✓ $package (already installed)"
      else
        echo "    Installing $package..."
        brew install "$package" >/dev/null 2>&1 || echo "    ⚠ Failed to install $package"
      fi
    done
    
    # Cask applications
    BREW_CASKS=(
      "orbstack"        # Docker alternative
    )
    
    for cask in "${BREW_CASKS[@]}"; do
      if brew list --cask "$cask" >/dev/null 2>&1; then
        echo "    ✓ $cask (already installed)"
      else
        echo "    Installing $cask..."
        brew install --cask "$cask" >/dev/null 2>&1 || echo "    ⚠ Failed to install $cask"
      fi
    done
    
  else
    echo "  ⚠ Homebrew not found - skipping package installation"
    echo "  Install Homebrew: /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
  fi

  # Run the ansible playbook for the rest (casks, App Store apps, defaults, dock, etc.)
  if command -v brew >/dev/null 2>&1; then
    if ! command -v ansible-playbook >/dev/null 2>&1; then
      echo "  Installing ansible..."
      brew install ansible >/dev/null 2>&1 || echo "  ⚠ Failed to install ansible"
    fi
    if command -v ansible-galaxy >/dev/null 2>&1; then
      echo "  Ensuring ansible community.general collection..."
      ansible-galaxy collection install community.general >/dev/null 2>&1 || true
    fi
    if command -v ansible-playbook >/dev/null 2>&1; then
      echo "==> Running ansible playbook (~/.config/yadm/bootstrap.yml)"
      ansible-playbook "$HOME/.config/yadm/bootstrap.yml"
    else
      echo "  ⚠ ansible-playbook not available - skipping playbook"
    fi
  fi
fi

# Install/update npm deps for pi extensions
for pkg in ~/.pi/agent/extensions/*/package.json; do
  dir="$(dirname "$pkg")"
  name="$(basename "$dir")"
  if [ ! -d "$dir/node_modules" ]; then
    echo "  Installing deps for extension: $name"
    (cd "$dir" && npm install --no-fund --no-audit)
  else
    echo "  Updating deps for extension: $name"
    (cd "$dir" && npm install --no-fund --no-audit 2>&1 | grep -v "up to date" || true)
  fi
done

echo "==> Done"

# If any tasks queued manual followups, print them now so the user sees them
# at the end of the run. These are commands the user needs to execute by hand.
if [ -s "$FOLLOWUPS_FILE" ]; then
  echo
  echo "==> Manual follow-ups required:"
  while IFS= read -r line; do
    echo "  $line"
  done < "$FOLLOWUPS_FILE"
  echo
fi
