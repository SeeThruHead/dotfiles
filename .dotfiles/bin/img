#!/usr/bin/env bash
# img — browse and preview images with chafa using j/k navigation

set -euo pipefail

dir="${1:-.}"
exts=("jpg" "jpeg" "png" "gif" "webp" "bmp" "tiff" "svg")

# Build find args
args=("find" "$dir" "-maxdepth" "1" "-type" "f" "(")
for i in "${!exts[@]}"; do
  ((i > 0)) && args+=("-o")
  args+=("-iname" "*.${exts[$i]}")
done
args+=(")")

# Collect images
mapfile -t images < <("${args[@]}" | sort)

if [[ ${#images[@]} -eq 0 ]]; then
  echo "No images found in $dir"
  exit 1
fi

idx=0
total=${#images[@]}

show_image() {
  clear
  local file="${images[$idx]}"
  local name
  name=$(basename "$file")
  echo -e "\033[1m[$((idx + 1))/$total] $name\033[0m"
  echo ""
  chafa --size="${COLUMNS:-80}x$((${LINES:-24} - 4))" "$file"
  echo ""
  echo -e "\033[2m j/↓=next  k/↑=prev  q=quit  o=open\033[0m"
}

show_image

while true; do
  # Read a single keypress (handle escape sequences for arrow keys)
  IFS= read -rsn1 key
  case "$key" in
    j)
      ((idx < total - 1)) && ((idx++)) && show_image
      ;;
    k)
      ((idx > 0)) && ((idx--)) && show_image
      ;;
    $'\x1b')
      # Arrow key escape sequence
      read -rsn2 arrow
      case "$arrow" in
        '[B') ((idx < total - 1)) && ((idx++)) && show_image ;;  # Down
        '[A') ((idx > 0)) && ((idx--)) && show_image ;;          # Up
      esac
      ;;
    o)
      open "${images[$idx]}" 2>/dev/null
      ;;
    q)
      clear
      exit 0
      ;;
  esac
done
