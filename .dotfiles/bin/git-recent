#!/usr/bin/env bash
# git-recent — interactive recent branch switcher
# Usage: git recent [count]
# Navigate with j/k, enter to switch, esc to cancel

set -euo pipefail

count="${1:-20}"

branch=$(
  git for-each-ref \
    --sort=-committerdate \
    --format='%(refname:short)|%(committerdate:relative)|%(subject)' \
    --count="$count" \
    refs/heads/ \
  | while IFS='|' read -r name date subject; do
      current=" "
      if [[ "$name" == "$(git symbolic-ref --short HEAD 2>/dev/null)" ]]; then
        current="*"
      fi
      printf '%s %-30s  %-18s  %s\n' "$current" "$name" "$date" "${subject:0:60}"
    done \
  | fzf \
      --ansi \
      --no-sort \
      --prompt="switch to> " \
      --header="  Branch                          Last commit           Message" \
      --bind="j:down,k:up" \
      --reverse \
  | awk '{if ($1 == "*") print $2; else print $1}'
)

if [[ -n "$branch" ]]; then
  git switch "$branch"
fi
