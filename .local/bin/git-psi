#!/usr/bin/env bash
# git-psi — push selected commits, rebased onto target
# Usage: git psi [--base <branch>] [--target <branch>] [--remote <remote>] [--dry-run]
# Navigate with j/k, space to toggle, tab to toggle, enter to confirm

set -euo pipefail

BASE_BRANCH="sk/process-compose"
TARGET_BRANCH="main"
REMOTE="origin"
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)   BASE_BRANCH="$2"; shift 2 ;;
    --target) TARGET_BRANCH="$2"; shift 2 ;;
    --remote) REMOTE="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    -h|--help)
      sed -n '2,5p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$CURRENT_BRANCH" == "HEAD" ]]; then
  echo "Error: detached HEAD state" >&2
  exit 1
fi

# Fetch latest target
echo "Fetching $REMOTE/$TARGET_BRANCH..."
git fetch "$REMOTE" "$TARGET_BRANCH" --quiet

# Get commits that are on the base branch but not on target (these get pre-deselected)
declare -A BASE_COMMITS
if git rev-parse --verify "$BASE_BRANCH" &>/dev/null; then
  while IFS= read -r hash; do
    BASE_COMMITS["$hash"]=1
  done < <(git log --format='%h' "$REMOTE/$TARGET_BRANCH".."$BASE_BRANCH" 2>/dev/null)
fi

# Gather ALL commits between target and HEAD (newest first for display)
mapfile -t COMMIT_LINES < <(git log --oneline "$REMOTE/$TARGET_BRANCH"..HEAD 2>/dev/null)

if [[ ${#COMMIT_LINES[@]} -eq 0 ]]; then
  echo "No commits found between $REMOTE/$TARGET_BRANCH and HEAD"
  exit 0
fi

# Build fzf input: feature commits first, then base commits tagged [base]
FZF_FEATURE=""
FZF_BASE=""
BASE_COUNT=0
for ((i = 0; i < ${#COMMIT_LINES[@]}; i++)); do
  line="${COMMIT_LINES[$i]}"
  hash="${line%% *}"
  msg="${line#* }"
  if [[ -n "${BASE_COMMITS[$hash]:-}" ]]; then
    FZF_BASE+="[base]  $hash  $msg"$'\n'
    ((BASE_COUNT++)) || true
  else
    FZF_FEATURE+="        $hash  $msg"$'\n'
  fi
done
FZF_INPUT="${FZF_FEATURE}${FZF_BASE}"

# Build start action: select all, then move to last and deselect base commits
DESELECT_CHAIN="select-all+last"
for ((i = 0; i < BASE_COUNT; i++)); do
  DESELECT_CHAIN+="+deselect+up"
done
DESELECT_CHAIN+="+first"

# Run fzf multi-select
SELECTED=$(
  echo -n "$FZF_INPUT" \
  | fzf \
      --multi \
      --ansi \
      --no-sort \
      --reverse \
      --prompt="push> " \
      --header="  pushing onto $TARGET_BRANCH → $REMOTE/$CURRENT_BRANCH
  space:toggle  tab:toggle  enter:confirm  esc:abort" \
      --bind="j:down,k:up,space:toggle" \
      --bind="start:${DESELECT_CHAIN}" \
) || { echo "Aborted."; exit 0; }

if [[ -z "$SELECTED" ]]; then
  echo "No commits selected. Nothing to push."
  exit 0
fi

# Parse selected lines to extract hashes, then reverse to oldest-first for cherry-pick
PICKS=()
while IFS= read -r sel_line; do
  # Strip leading whitespace and [base] tag, then grab the hash
  cleaned="${sel_line#"${sel_line%%[![:space:]]*}"}"
  cleaned="${cleaned#\[base\]}"
  cleaned="${cleaned#"${cleaned%%[![:space:]]*}"}"
  hash="${cleaned%% *}"
  PICKS+=("$hash")
done <<< "$SELECTED"

# Reverse to oldest-first for cherry-pick (tail -r is macOS tac)
mapfile -t PICKS < <(printf '%s\n' "${PICKS[@]}" | tail -r)

echo ""
echo "Selected ${#PICKS[@]} commit(s) to push:"
for h in "${PICKS[@]}"; do
  git log --oneline -1 "$h" | sed 's/^/  /'
done
echo ""

if $DRY_RUN; then
  echo "[dry-run] Would cherry-pick onto $REMOTE/$TARGET_BRANCH and push to $REMOTE/$CURRENT_BRANCH"
  exit 0
fi

# --- Execute ---

TMP_BRANCH="tmp/psi-$$"

# Stash any uncommitted changes
STASH_NEEDED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
  STASH_NEEDED=true
  git stash push -m "git-psi auto-stash" --quiet
fi

cleanup() {
  git checkout "$CURRENT_BRANCH" --quiet 2>/dev/null || true
  git branch -D "$TMP_BRANCH" 2>/dev/null || true
  if $STASH_NEEDED; then
    git stash pop --quiet 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Create temp branch from latest target, cherry-pick selected commits
git checkout -b "$TMP_BRANCH" "$REMOTE/$TARGET_BRANCH" --quiet

if ! git cherry-pick "${PICKS[@]}" --no-edit; then
  echo ""
  echo "Error: cherry-pick failed. Aborting." >&2
  git cherry-pick --abort 2>/dev/null || true
  exit 1
fi

# Push to remote
echo "Pushing to $REMOTE/$CURRENT_BRANCH..."
git push "$REMOTE" "$TMP_BRANCH:$CURRENT_BRANCH" --force-with-lease

echo ""
echo "✓ Pushed ${#PICKS[@]} commit(s) to $REMOTE/$CURRENT_BRANCH (rebased on $REMOTE/$TARGET_BRANCH)"
