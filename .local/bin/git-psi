#!/usr/bin/env bash
set -euo pipefail

# git-psi: Push selected commits, rebased onto a target branch.
#
# Usage: git psi [--base <branch>] [--target <branch>] [--remote <remote>] [--dry-run]
#
# Workflow:
#   1. Shows commits between <base> and HEAD in a TUI
#   2. All commits pre-selected; deselect any you don't want
#   3. Cherry-picks selected commits onto <target>, pushes to <remote>/<current-branch>
#   4. Local branch is never modified
#
# Keybindings:
#   j/↓    Move down
#   k/↑    Move up
#   space  Toggle selection
#   a      Select all
#   n      Deselect all
#   enter  Confirm and push
#   q/esc  Abort

BASE_BRANCH="sk/process-compose"
TARGET_BRANCH="main"
REMOTE="origin"
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)   BASE_BRANCH="$2"; shift 2 ;;
    --target) TARGET_BRANCH="$2"; shift 2 ;;
    --remote) REMOTE="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    -h|--help)
      sed -n '3,16p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$CURRENT_BRANCH" == "HEAD" ]]; then
  echo "Error: detached HEAD state" >&2
  exit 1
fi

# Gather commits (oldest first for cherry-pick order)
mapfile -t COMMIT_LINES < <(git log --reverse --oneline "$BASE_BRANCH".."HEAD" 2>/dev/null)

if [[ ${#COMMIT_LINES[@]} -eq 0 ]]; then
  echo "No commits found between $BASE_BRANCH and HEAD"
  exit 0
fi

# Parse into parallel arrays
HASHES=()
MESSAGES=()
SELECTED=()
for line in "${COMMIT_LINES[@]}"; do
  HASHES+=("${line%% *}")
  MESSAGES+=("${line#* }")
  SELECTED+=(1)
done

COUNT=${#HASHES[@]}
CURSOR=0

# --- TUI rendering ---

tui_draw() {
  # Move cursor to top of our drawing area and clear
  printf '\e[%dA' "$((COUNT + 3))" 2>/dev/null || true
  printf '\e[J'

  local selected_count=0
  for s in "${SELECTED[@]}"; do ((selected_count += s)) || true; done

  printf '\e[1m git psi \e[0m — %d/%d commits selected (pushing onto \e[33m%s\e[0m → \e[36m%s/%s\e[0m)\n' \
    "$selected_count" "$COUNT" "$TARGET_BRANCH" "$REMOTE" "$CURRENT_BRANCH"
  printf '\e[2m j/k:move  space:toggle  a:all  n:none  enter:push  q:abort\e[0m\n'

  for ((i = 0; i < COUNT; i++)); do
    local marker=" "
    [[ ${SELECTED[$i]} -eq 1 ]] && marker="●"
    local prefix="  "
    [[ $i -eq $CURSOR ]] && prefix="▸ "

    if [[ $i -eq $CURSOR ]]; then
      if [[ ${SELECTED[$i]} -eq 1 ]]; then
        printf '%s\e[32m[%s]\e[0m \e[1m%s\e[0m \e[2m%s\e[0m\n' "$prefix" "$marker" "${HASHES[$i]}" "${MESSAGES[$i]}"
      else
        printf '%s\e[90m[%s]\e[0m \e[1m%s\e[0m \e[2m%s\e[0m\n' "$prefix" "$marker" "${HASHES[$i]}" "${MESSAGES[$i]}"
      fi
    else
      if [[ ${SELECTED[$i]} -eq 1 ]]; then
        printf '%s\e[32m[%s]\e[0m %s %s\n' "$prefix" "$marker" "${HASHES[$i]}" "${MESSAGES[$i]}"
      else
        printf '%s\e[90m[%s]\e[0m \e[90m%s %s\e[0m\n' "$prefix" "$marker" "${HASHES[$i]}" "${MESSAGES[$i]}"
      fi
    fi
  done
  printf '\n'
}

# Read a single keypress (handles escape sequences)
read_key() {
  local key
  IFS= read -rsn1 key
  if [[ "$key" == $'\e' ]]; then
    local seq
    IFS= read -rsn1 -t 0.1 seq || true
    if [[ "$seq" == "[" ]]; then
      IFS= read -rsn1 -t 0.1 seq || true
      case "$seq" in
        A) echo "up"; return ;;
        B) echo "down"; return ;;
      esac
    fi
    echo "esc"; return
  fi
  case "$key" in
    j) echo "down" ;;
    k) echo "up" ;;
    " ") echo "space" ;;
    a) echo "all" ;;
    n) echo "none" ;;
    "") echo "enter" ;;
    q) echo "quit" ;;
    *) echo "" ;;
  esac
}

# Print initial blank lines so tui_draw has room to move up
for ((i = 0; i < COUNT + 3; i++)); do echo; done

# Save terminal settings, enable raw mode
ORIG_STTY=$(stty -g)
trap 'stty "$ORIG_STTY"; printf "\e[?25h"' EXIT
stty -echo -icanon
printf '\e[?25l'  # hide cursor

tui_draw

while true; do
  key=$(read_key)
  case "$key" in
    down)
      ((CURSOR < COUNT - 1)) && ((CURSOR++))
      ;;
    up)
      ((CURSOR > 0)) && ((CURSOR--))
      ;;
    space)
      SELECTED[$CURSOR]=$(( 1 - ${SELECTED[$CURSOR]} ))
      ;;
    all)
      for ((i = 0; i < COUNT; i++)); do SELECTED[$i]=1; done
      ;;
    none)
      for ((i = 0; i < COUNT; i++)); do SELECTED[$i]=0; done
      ;;
    enter)
      break
      ;;
    quit|esc)
      printf '\e[?25h'
      stty "$ORIG_STTY"
      echo "Aborted."
      exit 0
      ;;
  esac
  tui_draw
done

# Restore terminal
printf '\e[?25h'
stty "$ORIG_STTY"
trap - EXIT

# Collect selected commit hashes (in order, oldest first)
PICKS=()
for ((i = 0; i < COUNT; i++)); do
  [[ ${SELECTED[$i]} -eq 1 ]] && PICKS+=("${HASHES[$i]}")
done

if [[ ${#PICKS[@]} -eq 0 ]]; then
  echo "No commits selected. Nothing to push."
  exit 0
fi

echo ""
echo "Selected ${#PICKS[@]} commit(s) to push:"
for h in "${PICKS[@]}"; do
  git log --oneline -1 "$h" | sed 's/^/  /'
done
echo ""

if $DRY_RUN; then
  echo "[dry-run] Would cherry-pick onto $TARGET_BRANCH and push to $REMOTE/$CURRENT_BRANCH"
  exit 0
fi

# --- Execute ---

TMP_BRANCH="tmp/psi-$$"

# Stash any uncommitted changes
STASH_NEEDED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
  STASH_NEEDED=true
  git stash push -m "git-psi auto-stash" --quiet
fi

cleanup() {
  git checkout "$CURRENT_BRANCH" --quiet 2>/dev/null || true
  git branch -D "$TMP_BRANCH" 2>/dev/null || true
  if $STASH_NEEDED; then
    git stash pop --quiet 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Create temp branch from target, cherry-pick selected commits
git checkout -b "$TMP_BRANCH" "$REMOTE/$TARGET_BRANCH" --quiet

if ! git cherry-pick "${PICKS[@]}" --no-edit; then
  echo ""
  echo "Error: cherry-pick failed. Aborting." >&2
  git cherry-pick --abort 2>/dev/null || true
  exit 1
fi

# Push to remote
echo "Pushing to $REMOTE/$CURRENT_BRANCH..."
git push "$REMOTE" "$TMP_BRANCH:$CURRENT_BRANCH" --force-with-lease

echo ""
echo "✓ Pushed ${#PICKS[@]} commit(s) to $REMOTE/$CURRENT_BRANCH (based on $TARGET_BRANCH)"
