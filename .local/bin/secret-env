#!/usr/bin/env bash
# secret-env — Safe .env file operations that never expose secret values.
#
# Usage:
#   secret-env read <file>                         Show file with values redacted
#   secret-env check <file> <KEY>                  Check if a variable exists/has value
#   secret-env list [directory]                    List all .env files and their keys
#   secret-env copy <source> <target> <KEY>        Copy a variable between .env files
#   secret-env keys <file>                         List just the variable names

set -euo pipefail

usage() {
  echo "Usage: secret-env <command> [args...]"
  echo ""
  echo "Commands:"
  echo "  read  <file>                        Read .env file with values redacted"
  echo "  check <file> <KEY>                  Check if a variable exists and has a value"
  echo "  list  [directory]                   List all .env files and their variable names"
  echo "  copy  <source> <target> <KEY>       Copy a variable between .env files (on disk)"
  echo "  keys  <file>                        List just the variable names in a file"
  echo ""
  echo "Values are NEVER printed. Only key names and <SET>/<EMPTY> status."
  exit 1
}

require_file() {
  if [[ ! -f "$1" ]]; then
    echo "Error: File not found: $1" >&2
    exit 1
  fi
}

# Parse a value — strip quotes, report set/empty
classify_value() {
  local value="$1"
  local stripped="$value"
  # Trim whitespace
  stripped="${stripped#"${stripped%%[![:space:]]*}"}"
  stripped="${stripped%"${stripped##*[![:space:]]}"}"
  # Strip surrounding quotes
  if [[ "$stripped" =~ ^\"(.*)\"$ ]] || [[ "$stripped" =~ ^\'(.*)\'$ ]]; then
    stripped="${BASH_REMATCH[1]}"
  fi
  if [[ -z "$stripped" ]]; then
    echo "EMPTY"
  else
    echo "SET:${#stripped}"
  fi
}

# ── read ──────────────────────────────────────────────────────────
cmd_read() {
  [[ $# -lt 1 ]] && { echo "Usage: secret-env read <file>" >&2; exit 1; }
  local file="$1"
  require_file "$file"

  echo "# $file (values redacted)"
  echo ""

  while IFS= read -r line || [[ -n "$line" ]]; do
    local trimmed="${line#"${line%%[![:space:]]*}"}"

    # Blank lines
    if [[ -z "$trimmed" ]]; then
      echo ""; continue
    fi

    # Pure comments (not commented-out vars)
    if [[ "$trimmed" =~ ^# ]] && ! [[ "$trimmed" =~ ^#[[:space:]]*[A-Za-z_][A-Za-z0-9_]*= ]]; then
      echo "$line"; continue
    fi

    # Match: optional comment prefix, optional export, KEY=VALUE
    if [[ "$trimmed" =~ ^(#[[:space:]]*)?(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=(.*) ]]; then
      local prefix="${BASH_REMATCH[1]:-}"
      local key="${BASH_REMATCH[3]}"
      local value="${BASH_REMATCH[4]}"
      local status
      status=$(classify_value "$value")

      if [[ "$status" == "EMPTY" ]]; then
        echo "${prefix}${key}=<EMPTY>"
      else
        echo "${prefix}${key}=<SET>"
      fi
    else
      echo "$line"
    fi
  done < "$file"
}

# ── check ─────────────────────────────────────────────────────────
cmd_check() {
  [[ $# -lt 2 ]] && { echo "Usage: secret-env check <file> <KEY>" >&2; exit 1; }
  local file="$1" key="$2"
  require_file "$file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    local trimmed="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$trimmed" ]] && continue
    [[ "$trimmed" =~ ^# ]] && continue

    if [[ "$trimmed" =~ ^(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=(.*) ]]; then
      if [[ "${BASH_REMATCH[2]}" == "$key" ]]; then
        local status
        status=$(classify_value "${BASH_REMATCH[3]}")
        if [[ "$status" == "EMPTY" ]]; then
          echo "✅ $key exists in $file but is EMPTY"
        else
          local len="${status#SET:}"
          echo "✅ $key is SET in $file ($len characters)"
        fi
        exit 0
      fi
    fi
  done < "$file"

  echo "❌ $key is NOT found in $file"
  exit 1
}

# ── list ──────────────────────────────────────────────────────────
cmd_list() {
  local dir="${1:-.}"
  if [[ ! -d "$dir" ]]; then
    echo "Error: Directory not found: $dir" >&2
    exit 1
  fi

  local files
  files=$(find "$dir" -maxdepth 5 \( -name '.env' -o -name '.env.*' \) \
    ! -path '*/node_modules/*' ! -path '*/.git/*' 2>/dev/null | sort)

  if [[ -z "$files" ]]; then
    echo "No .env files found in $dir"
    exit 0
  fi

  while IFS= read -r file; do
    echo "📄 $file"
    local keys=()
    while IFS= read -r line || [[ -n "$line" ]]; do
      local trimmed="${line#"${line%%[![:space:]]*}"}"
      [[ -z "$trimmed" ]] && continue
      [[ "$trimmed" =~ ^# ]] && continue
      if [[ "$trimmed" =~ ^(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)= ]]; then
        keys+=("${BASH_REMATCH[2]}")
      fi
    done < "$file"

    if [[ ${#keys[@]} -gt 0 ]]; then
      echo "   Variables: ${keys[*]}"
    else
      echo "   (no variables)"
    fi
    echo ""
  done <<< "$files"
}

# ── copy ──────────────────────────────────────────────────────────
cmd_copy() {
  [[ $# -lt 3 ]] && { echo "Usage: secret-env copy <source> <target> <KEY>" >&2; exit 1; }
  local source="$1" target="$2" key="$3"
  require_file "$source"

  # Find the value in source
  local found_line=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    local trimmed="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$trimmed" ]] && continue
    [[ "$trimmed" =~ ^# ]] && continue
    if [[ "$trimmed" =~ ^(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=(.*) ]]; then
      if [[ "${BASH_REMATCH[2]}" == "$key" ]]; then
        found_line="${key}=${BASH_REMATCH[3]}"
        break
      fi
    fi
  done < "$source"

  if [[ -z "$found_line" ]]; then
    echo "Error: $key not found in $source" >&2
    exit 1
  fi

  # If target exists, replace or append
  if [[ -f "$target" ]]; then
    if grep -qE "^(export[[:space:]]+)?${key}=" "$target" 2>/dev/null; then
      # Replace existing line
      local tmp
      tmp=$(mktemp)
      while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" =~ ^(export[[:space:]]+)?${key}= ]]; then
          echo "$found_line"
        else
          echo "$line"
        fi
      done < "$target" > "$tmp"
      mv "$tmp" "$target"
      echo "✅ Updated $key in $target (value not shown)"
    else
      echo "$found_line" >> "$target"
      echo "✅ Appended $key to $target (value not shown)"
    fi
  else
    echo "$found_line" > "$target"
    echo "✅ Created $target with $key (value not shown)"
  fi
}

# ── keys ──────────────────────────────────────────────────────────
cmd_keys() {
  [[ $# -lt 1 ]] && { echo "Usage: secret-env keys <file>" >&2; exit 1; }
  local file="$1"
  require_file "$file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    local trimmed="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$trimmed" ]] && continue
    [[ "$trimmed" =~ ^# ]] && continue
    if [[ "$trimmed" =~ ^(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)= ]]; then
      echo "${BASH_REMATCH[2]}"
    fi
  done < "$file"
}

# ── dispatch ──────────────────────────────────────────────────────
[[ $# -lt 1 ]] && usage

case "$1" in
  read)  shift; cmd_read "$@" ;;
  check) shift; cmd_check "$@" ;;
  list)  shift; cmd_list "$@" ;;
  copy)  shift; cmd_copy "$@" ;;
  keys)  shift; cmd_keys "$@" ;;
  -h|--help) usage ;;
  *) echo "Unknown command: $1" >&2; usage ;;
esac
