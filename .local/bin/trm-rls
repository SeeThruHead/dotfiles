#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=false
YES=false

usage() {
  cat <<EOF
trm-rls — Topstep release manager

Usage:
  trm-rls cut              Auto-increment version, create release branch, tag staging, create GH release
  trm-rls retag            Delete staging tag/release, retag branch at HEAD, recreate GH release
  trm-rls promote          Tag current release branch as prod, create draft GH release
  trm-rls publish          Publish the draft prod release
  trm-rls msg [tag]        Show Slack-formatted release message (defaults to latest prod)
  trm-rls status           Show current release branch and tags
  trm-rls --help           Show this help

Options:
  --dry-run                Show what would happen without making any changes
  --yes, -y                Skip confirmation prompts

EOF
}

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "⚠ $*"; }

JIRA_BASE="https://topsteptrader.atlassian.net/browse"
CD_WORKFLOW="0. TRM Continuous Delivery"

# Show CD pipeline status for a given tag
show_cd_status() {
  local tag="$1"
  local run_json
  run_json=$(gh run list --workflow "$CD_WORKFLOW" --branch "$tag" --limit 1 --json databaseId,status,conclusion,url 2>/dev/null || true)

  local run_id
  run_id=$(echo "$run_json" | jq -r '.[0].databaseId // empty' 2>/dev/null || true)
  [[ -z "$run_id" ]] && return

  local run_status run_conclusion run_url
  run_status=$(echo "$run_json" | jq -r '.[0].status')
  run_conclusion=$(echo "$run_json" | jq -r '.[0].conclusion // empty')
  run_url=$(echo "$run_json" | jq -r '.[0].url')

  # Summary line
  local summary="  CD: ${run_status}"
  [[ -n "$run_conclusion" ]] && summary="${summary} (${run_conclusion})"
  echo "${summary}"
  echo "  ${run_url}"

  # Show job details: in_progress, failed, or queued jobs
  local jobs
  jobs=$(gh run view "$run_id" --json jobs --jq '.jobs[] | select(.status != "completed" or .conclusion == "failure") | "    \(if .conclusion == "failure" then "✗" elif .status == "in_progress" then "▶" else "⏳" end) \(.name) — \(.status)\(if .conclusion and .conclusion != "" then " (\(.conclusion))" else "" end)"' 2>/dev/null || true)

  if [[ -n "$jobs" ]]; then
    echo "$jobs"
  else
    # All completed — show final count
    local total
    total=$(gh run view "$run_id" --json jobs --jq '.jobs | length' 2>/dev/null || true)
    echo "    ✓ All ${total} jobs completed"
  fi
}

# Format GitHub release notes into Slack-ready output
# Input: version tag, reads release body from gh
# Output: Slack-pasteable format with Jira links
format_slack_notes() {
  local tag="$1"
  local body
  body=$(gh release view "$tag" --json body --jq '.body' | tr -d '\r')

  # Strip -staging suffix for display
  local display_ver="${tag%-staging}"

  echo ":white_check_mark: TRM ${display_ver}"
  echo '```'

  local first=true

  # Parse each PR line: "* Title by @user in https://..."
  echo "$body" | grep '^\* ' | while IFS= read -r line; do
    local title
    title=$(echo "$line" | sed 's/^\* //' | sed 's/ by @.*//')

    local ticket
    ticket=$(echo "$title" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)

    # Skip items without a Jira ticket
    [[ -n "$ticket" ]] || continue

    local clean_title
    clean_title=$(echo "$title" | sed -E 's/^[A-Z]+-[0-9]+ [-:] *//' | sed -E 's/^[A-Z]+-[0-9]+ //')

    if $first; then
      first=false
    else
      echo ""
    fi

    echo "$clean_title"
    echo "${JIRA_BASE}/${ticket}"
  done
  echo '```'
}

# Prompt for confirmation, auto-yes if --yes
confirm() {
  if $YES; then return 0; fi
  local prompt="$1"
  read -r -p "$prompt [y/N] " answer
  [[ "$answer" =~ ^[Yy]$ ]]
}

# Run a command, or print it if dry run
run() {
  if $DRY_RUN; then
    echo "  [dry-run] $*"
  else
    "$@"
  fi
}

# Get latest vX.Y.Z tag (ignoring -staging), return "none" if no tags exist
get_latest_version() {
  gh release list --limit 100 --json tagName --jq '.[].tagName' 2>/dev/null \
    | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' \
    | sort -V \
    | tail -1 \
    || echo "none"
}

# Bump patch: v0.5.82 -> v0.5.83
bump_patch() {
  local ver="$1"
  local major minor patch
  major=$(echo "$ver" | sed 's/^v//' | cut -d. -f1)
  minor=$(echo "$ver" | sed 's/^v//' | cut -d. -f2)
  patch=$(echo "$ver" | sed 's/^v//' | cut -d. -f3)
  echo "v${major}.${minor}.$((patch + 1))"
}

# Find the current release branch (most recent release/* branch)
current_release_branch() {
  git branch -r --sort=-committerdate --list 'origin/release/v*' 2>/dev/null \
    | head -1 \
    | sed 's|^ *origin/||' \
    || echo ""
}

# Extract version from branch name: release/v0.5.82 -> v0.5.82
version_from_branch() {
  echo "$1" | sed 's|^release/||'
}

# Verify release notes contain all PRs between two tags
# Usage: verify_notes <release_tag> <since_tag>
verify_notes() {
  local release_tag="$1"
  local since_tag="$2"

  # Get PR numbers from commits
  local expected_prs
  expected_prs=$(git log --oneline "$since_tag..origin/$(current_release_branch)" \
    | grep -oE '#[0-9]+' | sort -u)

  if [[ -z "$expected_prs" ]]; then
    return 0
  fi

  # Get release notes body
  local body
  body=$(gh release view "$release_tag" --json body --jq '.body' 2>/dev/null || true)

  local missing=()
  while IFS= read -r pr; do
    if ! echo "$body" | grep -q "$pr"; then
      missing+=("$pr")
    fi
  done <<< "$expected_prs"

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo ""
    warn "Release notes are missing ${#missing[@]} PR(s):"
    for pr in "${missing[@]}"; do
      local title
      title=$(git log --oneline "$since_tag..origin/$(current_release_branch)" | grep "$pr" | head -1)
      echo "  $title"
    done
    echo ""
    warn "Notes may need to be regenerated. Check --notes-start-tag baseline."
  else
    echo "✓ Release notes include all ${#expected_prs[@]} PR(s)"
  fi
}

cmd_cut() {
  # Make sure we're in a git repo
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"

  # Fetch latest
  git fetch origin --tags --quiet

  local latest
  latest=$(get_latest_version)

  local next
  if [[ "$latest" == "none" ]]; then
    next="v0.0.1"
    echo "No existing releases found. Starting at $next"
  else
    next=$(bump_patch "$latest")
    echo "Latest prod release: $latest"
    echo "Next version: $next"
  fi

  local branch="release/$next"
  local staging_tag="${next}-staging"

  echo ""
  confirm "Cut $branch from main and tag $staging_tag?" || { echo "Aborted."; exit 0; }

  echo ""
  echo "Creating branch $branch from origin/main..."
  run git checkout -b "$branch" origin/main
  run git push -u origin "$branch"

  echo "Creating release $staging_tag..."
  run gh release create "$staging_tag" \
    --target "$branch" \
    --title "$staging_tag" \
    --generate-notes \
    --notes-start-tag "$latest"

  echo ""
  echo "✓ Branch: $branch"
  echo "✓ Tag: $staging_tag"
  if ! $DRY_RUN; then
    echo "✓ Release: $(gh browse --no-browser)/releases/tag/$staging_tag"
    verify_notes "$staging_tag" "$latest"
    echo ""
    format_slack_notes "$staging_tag"
  fi
}

cmd_retag() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
  git fetch origin --tags --quiet

  local branch
  branch=$(current_release_branch)
  [[ -n "$branch" ]] || die "no release branch found"

  local version
  version=$(version_from_branch "$branch")
  local staging_tag="${version}-staging"

  echo "Release branch: $branch"
  echo "Staging tag: $staging_tag"
  echo ""

  # Check staging release exists
  if ! gh release view "$staging_tag" >/dev/null 2>&1; then
    die "no staging release found for $staging_tag"
  fi

  confirm "Delete and recreate $staging_tag at current $branch HEAD?" || { echo "Aborted."; exit 0; }

  echo ""
  echo "Deleting release $staging_tag..."
  run gh release delete "$staging_tag" --yes --cleanup-tag

  # Make sure we're on the release branch and up to date
  run git checkout "$branch"
  run git pull origin "$branch" --quiet

  # Find previous prod tag for notes baseline
  local prev_prod
  prev_prod=$(get_latest_version)

  echo "Recreating release $staging_tag (notes from $prev_prod)..."
  run gh release create "$staging_tag" \
    --target "$branch" \
    --title "$staging_tag" \
    --generate-notes \
    --notes-start-tag "$prev_prod"

  echo ""
  echo "✓ Retagged $staging_tag at $(git rev-parse --short HEAD)"
  if ! $DRY_RUN; then
    echo "✓ Release: $(gh browse --no-browser)/releases/tag/$staging_tag"
    verify_notes "$staging_tag" "$prev_prod"
    echo ""
    format_slack_notes "$staging_tag"
  fi
}

cmd_promote() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
  git fetch origin --tags --quiet

  local branch
  branch=$(current_release_branch)
  [[ -n "$branch" ]] || die "no release branch found"

  local version
  version=$(version_from_branch "$branch")
  local staging_tag="${version}-staging"
  local prod_tag="$version"

  echo "Release branch: $branch"
  echo "Staging tag: $staging_tag"
  echo "Prod tag: $prod_tag"
  echo ""

  # Check prod tag already exists — offer to re-promote
  if gh release view "$prod_tag" >/dev/null 2>&1; then
    warn "Prod release $prod_tag already exists."
    echo ""
    confirm "Delete $prod_tag and re-promote?" || { echo "Aborted."; exit 0; }
    echo ""
    echo "Deleting release $prod_tag..."
    run gh release delete "$prod_tag" --yes --cleanup-tag
    echo ""
  fi

  # Check release branch HEAD matches staging tag
  local branch_sha staging_sha
  branch_sha=$(git rev-parse "origin/$branch")
  staging_sha=$(git rev-parse "$staging_tag" 2>/dev/null || die "staging tag $staging_tag not found")

  if [[ "$branch_sha" != "$staging_sha" ]]; then
    echo "⚠ Release branch has diverged from staging tag!"
    echo ""
    echo "  $staging_tag:  ${staging_sha:0:10}"
    echo "  origin/$branch: ${branch_sha:0:10}"
    echo ""
    echo "Diff between staging tag and branch:"
    git log --oneline "$staging_sha...$branch_sha"
    echo ""
    die "retag staging first (trm-rls retag) before promoting"
  fi

  confirm "Tag $branch as $prod_tag (production)?" || { echo "Aborted."; exit 0; }

  # Make sure we're on the release branch and up to date
  run git checkout "$branch"
  run git pull origin "$branch" --quiet

  # Find previous prod tag for notes baseline
  local prev_prod
  prev_prod=$(get_latest_version)
  # If the latest prod IS this version (shouldn't happen, but guard), fall back
  if [[ "$prev_prod" == "$version" ]]; then
    die "prod release $version already exists"
  fi

  echo ""
  echo "Creating production release $prod_tag (notes from $prev_prod)..."
  run gh release create "$prod_tag" \
    --target "$branch" \
    --title "$prod_tag" \
    --generate-notes \
    --notes-start-tag "$prev_prod" \
    --draft

  echo ""
  echo "✓ Tag: $prod_tag (draft)"
  if ! $DRY_RUN; then
    echo "✓ Release: $(gh browse --no-browser)/releases/tag/$prod_tag"
    verify_notes "$prod_tag" "$prev_prod"
    echo ""
    echo "Run 'trm-rls publish' to publish the release when ready."
    echo ""
    format_slack_notes "$prod_tag"
  fi
}

cmd_publish() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
  git fetch origin --tags --quiet

  local branch
  branch=$(current_release_branch)
  [[ -n "$branch" ]] || die "no release branch found"

  local version
  version=$(version_from_branch "$branch")
  local prod_tag="$version"

  # Check the release exists and is a draft
  local is_draft
  is_draft=$(gh release view "$prod_tag" --json isDraft --jq '.isDraft' 2>/dev/null || true)

  if [[ -z "$is_draft" ]]; then
    die "no release found for $prod_tag"
  fi

  if [[ "$is_draft" != "true" ]]; then
    die "$prod_tag is already published"
  fi

  echo "Draft release: $prod_tag"
  echo ""

  confirm "Publish $prod_tag?" || { echo "Aborted."; exit 0; }

  echo ""
  run gh release edit "$prod_tag" --draft=false

  echo ""
  echo "✓ Published $prod_tag"
  if ! $DRY_RUN; then
    echo "✓ Release: $(gh browse --no-browser)/releases/tag/$prod_tag"
  fi
}

cmd_msg() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
  git fetch origin --tags --quiet

  local tag="${args[1]:-}"

  if [[ -z "$tag" ]]; then
    tag=$(get_latest_version)
    [[ "$tag" != "none" ]] || die "no prod releases found"
  fi

  if ! gh release view "$tag" >/dev/null 2>&1; then
    die "no release found for $tag"
  fi

  format_slack_notes "$tag"
}

cmd_status() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
  git fetch origin --tags --quiet

  local branch
  branch=$(current_release_branch)

  if [[ -z "$branch" ]]; then
    echo "No release branch found."
  else
    local version
    version=$(version_from_branch "$branch")
    echo "Release branch: $branch"
    echo ""

    if gh release view "${version}-staging" >/dev/null 2>&1; then
      echo "Staging: ${version}-staging ✓"
      gh release view "${version}-staging" --json publishedAt,targetCommitish --jq '"  Published: \(.publishedAt)\n  Target branch: \(.targetCommitish)"'
      local staging_cd
      show_cd_status "${version}-staging"
    else
      echo "Staging: none"
    fi

    if gh release view "$version" >/dev/null 2>&1; then
      echo "Prod: $version ✓"
      gh release view "$version" --json publishedAt,targetCommitish --jq '"  Published: \(.publishedAt)\n  Target branch: \(.targetCommitish)"'
      show_cd_status "$version"
    else
      echo "Prod: none"
    fi
  fi

  echo ""
  echo "Latest prod releases:"
  gh release list --limit 5 --json tagName,publishedAt --jq '.[] | select(.tagName | test("^v[0-9]+\\.[0-9]+\\.[0-9]+$")) | "  \(.tagName)  \(.publishedAt)"' 2>/dev/null || echo "  (none)"
}

# Parse --dry-run from any position
args=()
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --yes|-y) YES=true ;;
    *) args+=("$arg") ;;
  esac
done

if $DRY_RUN; then
  echo "=== DRY RUN MODE — no changes will be made ==="
  echo ""
fi

case "${args[0]:-}" in
  cut)     cmd_cut ;;
  retag)   cmd_retag ;;
  promote) cmd_promote ;;
  publish) cmd_publish ;;
  msg)     cmd_msg ;;
  status)  cmd_status ;;
  --help|-h|"") usage ;;
  *) die "unknown command: ${args[0]}. Run trm-rls --help" ;;
esac
