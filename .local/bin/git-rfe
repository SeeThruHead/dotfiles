#!/usr/bin/env bash
# git-rfe — reflog explorer with diff preview
# Usage: git rfe [count]
# Browse recent reflog entries, enter copies hash to clipboard

set -euo pipefail
LIB_DIR="${HOME}/.local/lib"
source "$LIB_DIR/git-fzf-lib.sh"

count="${1:-200}"

git reflog --format='%h  %gd  %gs  (%cr)' --no-abbrev-commit -n "$count" \
| fzf \
    "${FZF_GIT_DEFAULTS[@]}" \
    --prompt="reflog> " \
    --header="  j/k:navigate  enter:copy hash  esc:quit" \
    --bind="enter:execute-silent(echo -n {1} | pbcopy)+abort" \
    --preview-window="right,65%,wrap" \
    --preview="
      source \"$LIB_DIR/git-fzf-lib.sh\"
      git_commit_preview {1}
    "
